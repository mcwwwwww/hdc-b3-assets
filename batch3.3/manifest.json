  "contact_form": "Every site gets a contact form posting to https://formspree.io/f/mpqgeoaj with method POST, fields: name, phone, message, and a hidden input name='_subject' value='<business> enquiry'. Also show the business phone number prominently with a tel: link.",
  "phone_rule": "Use the exact phone (and landline if present) given in this manifest. Never invent phone numbers, emails, addresses, prices, or reviews.",
  "email_rule": "Only show an email address if the manifest email field is non-empty; use it exactly as written.",
  "footer": "Small footer: '<business> \u2014 <town>, <county>'. No fake copyright years, no invented company registration numbers.",
  "seo": "Each page: <title><business> | <category> in <town></title> and a meta description using the ad_text.",
  "deliverable": "Zip all 20 files as batch3.N-sites.zip (N = this manifest's number) and provide a download link or upload URL (litterbox.catbox.moe 72h, or any fetchable URL)."
